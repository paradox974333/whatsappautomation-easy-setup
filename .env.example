# Port to run the application on
PORT=3000

# Cerebras Inference API Key (Required)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Cerebras Model (Optional, defaults to llama-3.3-70b)
CEREBRAS_MODEL=llama-3.3-70b

# WPPConnect session identifier (Optional, defaults to socialbuzzz18-bot)
WPP_SESSION_NAME=socialbuzzz18-bot

# Logging detail level: error, warn, info, debug (Optional, defaults to info)
LOG_LEVEL=info
