# ============================================================
#  Copy this file to .env and fill in your own values.
#  NEVER commit your real .env — it contains secrets.
# ============================================================

# --- Core (required) ---

# Cerebras Inference API key — get one free at https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here

# --- AI model (optional) ---

# Any model your Cerebras account supports
CEREBRAS_MODEL=llama-3.3-70b

# Path to the editable bot persona. Edit prompt/persona.md to rebrand the bot
# for YOUR business — no code changes needed.
# PERSONA_FILE=prompt/persona.md

# --- Server (optional) ---

PORT=3000
LOG_LEVEL=info

# --- Database (optional) ---
# Defaults to a local MongoDB. With docker-compose this is set for you.
# MONGODB_URI=mongodb://localhost:27017/whatsapp-bot

# --- WhatsApp session (optional) ---

WPP_SESSION_NAME=my-business-bot

# --- Lead / booking integration (optional) ---

# Your business owner/admin WhatsApp number that receives lead & booking alerts
OWNER_PHONE_NUMBER=910000000000

# Meeting link shared when a customer books a call
MEETING_LINK=https://meet.google.com/your-meeting-link

# How long (minutes) to wait before sending an automated follow-up
FOLLOW_UP_DELAY_MINUTES=1440

# Optional outbound webhook — captured leads are POSTed here (e.g. your CRM/Zapier)
# CRM_WEBHOOK_URL=

# --- Advanced (usually leave unset) ---
# UPLOAD_DIR=
# TOKEN_DIR=
# PUPPETEER_EXECUTABLE_PATH=
